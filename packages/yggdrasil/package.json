{
  "name": "@platob/yggdrasil",
  "version": "0.2.0",
  "description": "Client-side replication of the Python yggdrasil package — MIME/media-type registry, URL value type, and more. Kept in parity with python/src/yggdrasil.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean --out-dir dist --external apache-arrow",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": ["yggdrasil", "mime", "media-type", "url", "path", "http", "arrow"],
  "peerDependencies": {
    "apache-arrow": ">=17"
  },
  "peerDependenciesMeta": {
    "apache-arrow": { "optional": true }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/platob/yggdrasil.git",
    "directory": "packages/yggdrasil"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "apache-arrow": "^17.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
