{
  "name": "@platob/yggdrasil",
  "version": "0.3.12",
  "description": "Yggdrasil for JS/TS — the cross-compatible twin of the Python yggdrasil package, optimized for JS. Mirrors the Python module surface (enums, url, path, data typing, io) so backend (Python) and frontend (JS) speak one contract for high-performance communication, leveraging Apache Arrow and polars (and later Spark).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean --out-dir dist --external apache-arrow",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": ["yggdrasil", "mime", "media-type", "url", "path", "http", "arrow"],
  "peerDependencies": {
    "apache-arrow": ">=17"
  },
  "peerDependenciesMeta": {
    "apache-arrow": { "optional": true }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/platob/yggdrasil.git",
    "directory": "packages/yggdrasil"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "apache-arrow": "^17.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
