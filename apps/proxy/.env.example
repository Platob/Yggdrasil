# Copy this file to .env and adjust values as needed.

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# API
API_V1_PREFIX=/api/v1

# Frontend proxy – all non-/api/v1 requests are forwarded here
FRONTEND_UPSTREAM=http://localhost:5173

# Optional path prefix to strip before forwarding to the upstream
# e.g. set to /app to forward /app/index.html -> upstream /index.html
FRONTEND_STRIP_PREFIX=
